{
	"compilerOptions": {
		"target": "es2022",
		"module": "commonjs",
		"outDir": "./dist",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"typeRoots": ["./node_modules/@types", "./node_modules/", "./src/types"],
		"types": ["vitest/globals", "node"]
	},
	"include": ["src/**/*.ts", "_tests_/**/*.ts", "_mocks_/**/*.ts"]
}
